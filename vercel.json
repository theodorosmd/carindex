{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://carindex-production.up.railway.app/api/:path*" },
    { "source": "/sitemap.xml", "destination": "https://carindex-production.up.railway.app/sitemap.xml" },
    { "source": "/prix-marche", "destination": "https://carindex-production.up.railway.app/prix-marche" },
    { "source": "/prix-marche/:brand", "destination": "https://carindex-production.up.railway.app/prix-marche/:brand" },
    { "source": "/prix-marche/:brand/:model", "destination": "https://carindex-production.up.railway.app/prix-marche/:brand/:model" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
