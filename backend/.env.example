# Copier en .env et remplir les valeurs
# cp .env.example .env

# === Déploiement Railway (requis) ===
# URL du frontend Vercel - CORS autorise cette origine
# FRONTEND_URL=https://carindex-delta.vercel.app
# Secret pour les JWT (auth) - générer un secret fort en prod
# JWT_SECRET=ton-secret-aleatoire-fort

# Ingest direct Supabase (API key pour /api/v1/ingest/public/*)
# INGEST_API_KEY=ton-secret-pour-scrapers

# Supabase (requis pour l'import)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx
# Optionnel: pour migrations si DATABASE_URL inaccessible (npm run migrate:020:api)
# SUPABASE_ACCESS_TOKEN=sbp_xxx  # https://supabase.com/dashboard/account/tokens

# Scraping continu : tourne tous les scrapers jusqu'à épuisement, puis recommence
# Quand true, désactive les auto_scrapers (cron) et le daily scraping
# Utilisé sur VPS 24/7 — voir DEPLOY_VPS.md
# ENABLE_CONTINUOUS_SCRAPING=true
# CONTINUOUS_SCRAPE_INTERVAL_HOURS=0  # 0 = redémarrage immédiat après chaque cycle
# SCRAPE_CONCURRENCY=8  # Scrapers en parallèle (défaut: 3, 6-8 pour VPS 16GB)
# SCRAPER_RETRIES=3     # Tentatives par scraper en cas d'échec transitoire (timeout, réseau)
# SCRAPER_RETRY_DELAY_MS=15000  # Délai entre 2 tentatives (15s)
# FOCUSED_SOURCES=blocket,leboncoin,autoscout24,largus,lacentrale,mobile.de  # défaut: ces 6 seulement
# FOCUSED_SOURCES=all   # pour scraper toutes les sources

# VPS scraping worker : désactiver les autres jobs si vous ne voulez que le scraping
# ENABLE_DAILY_SCRAPING=false
# ENABLE_AUTO_SCRAPERS=false
# ENABLE_IMAGE_BACKFILL=false
# ENABLE_ARBITRAGE_DETECTION=false
# ENABLE_RAW_LISTINGS_PROCESSOR=true

# Bytbil import depuis scraper_listings (Supabase)
# ENABLE_SUPABASE_BYTBIL_IMPORT=false  # désactiver quand focus sur 6 sources (blocket, leboncoin, etc.)

# Django import (désactivé - bytbil passe par Supabase)
# ENABLE_DJANGO_IMPORT=true
# ENABLE_DJANGO_LEBONCOIN_IMPORT=true
# SUPABASE_BYTBIL_IMPORT_CRON=0 3 * * *  # défaut: 3h
# RUN_SUPABASE_BYTBIL_IMPORT_ON_STARTUP=true  # lancer au démarrage

# Django mobile.de API (port 8002 - Bytbil=8001)
DJANGO_MOBILEDE_BASE_URL=http://75.119.141.234:8002
DJANGO_MOBILEDE_USERNAME=admin
DJANGO_MOBILEDE_PASSWORD=xxx
# Filtrer status=OK uniquement (~1M listings)
DJANGO_API_CARS_QUERY=status=OK

# Scrape.do (REQUIS en prod pour LeBonCoin, Subito, coches.net, OtoMoto, 2ememain)
# Fallback anti-bot pour Blocket, Bytbil, mobile.de, Gaspedaal, etc.
# Sans token: plusieurs scrapers échoueront. https://scrape.do
SCRAPE_DO_TOKEN=

# mobile.de : accélérer le scraping (serveur dédié)
# MOBILEDE_MAX_PAGES=200        # pages par run (défaut 100)
# MOBILEDE_CONCURRENT_PAGES=8   # pages en parallèle (défaut 5)
# MOBILEDE_BATCH_DELAY_MS=2500  # délai entre lots (réduit rate limits scrape.do)
# MOBILEDE_ESTIMATED_SAVED_PER_DAY=430000  # override estimation "→ 100%" si Oleg fait ~6M/14j (optionnel)
# MOBILEDE_QUEUE_DELAY_MS=1500  # délai entre chaque URL traitée par le worker (défaut 1500)


# Parallélisme pour les autres sources (défaut 5)
# AUTOSCOUT24_CONCURRENT_PAGES=5
# BLOCKET_CONCURRENT_PAGES=5
# BLOCKET_CONCURRENT_DETAILS=5
# LEBONCOIN_CONCURRENT_PAGES=5
# LEBONCOIN_CONCURRENT_DETAILS=5
# LACENTRALE_CONCURRENT_PAGES=5
# LACENTRALE_CONCURRENT_DETAILS=5
# LARGUS_MAX_PAGES=50
# LARGUS_CONCURRENT_DETAILS=5

# VPS : utiliser Chromium système pour éviter "libglib-2.0.so.0" et erreurs Puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Reprise import (page où reprendre après interruption)
# DJANGO_IMPORT_START_PAGE=6157
# Si l'API Django utilise ?page= au lieu de ?offset= :
# DJANGO_IMPORT_USE_PAGE_PARAM=1
