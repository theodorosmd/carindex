# Copier en .env et remplir les valeurs
# npm run setup:local-env   OU   cp .env.example .env
# Pour check:growth en local : copier SUPABASE_URL et SUPABASE_SERVICE_ROLE_KEY depuis Railway → Variables (voir SETUP_LOCAL.md)

# === Déploiement Railway (requis) ===
# URL du frontend Vercel - CORS autorise cette origine
# FRONTEND_URL=https://carindex-delta.vercel.app
# Secret pour les JWT (auth) - générer un secret fort en prod
# JWT_SECRET=ton-secret-aleatoire-fort

# Ingest direct Supabase (API key pour /api/v1/ingest/public/*)
# INGEST_API_KEY=ton-secret-pour-scrapers

# Supabase (requis pour l'import)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx
# Optionnel: pour migrations si DATABASE_URL inaccessible (npm run migrate:020:api)
# SUPABASE_ACCESS_TOKEN=sbp_xxx  # https://supabase.com/dashboard/account/tokens

# Ingest : uniquement nouveaux listings (pas de mise à jour) — maximise la croissance du total
# INGEST_CREATE_ONLY=true

# UN SEUL SYSTÈME DE SCRAPING : run-all-scrapers-full
# DÉFAUT: mode continu H24 (tous les sites, boucle infinie)
# ENABLE_CONTINUOUS_SCRAPING=false  # désactiver pour revenir au cron quotidien
# CONTINUOUS_SCRAPE_INTERVAL_HOURS=0  # 0 = redémarrage immédiat après chaque cycle
# SCRAPE_CRON=0 3 * * *  # si cron quotidien (minute hour day month dow)
# SCRAPE_CONCURRENCY=3   # Scrapers en parallèle (défaut: 3)
# SCRAPE_CONCURRENCY=8   # Recommandé pour accélérer la croissance
# SCRAPE_CONCURRENCY=6   # VPS 16GB : 6 scrapers en parallèle
# SCRAPER_RETRIES=3      # Tentatives par scraper en cas d'échec transitoire
# SCRAPER_RETRY_DELAY_MS=15000
# FOCUSED_SOURCES=all    # défaut en mode H24 (toutes les sources)
# FOCUSED_SOURCES=blocket,leboncoin,mobile.de  # ou liste ciblée

# Raw listings: batch + fréquence pour accélérer la croissance
# PROCESS_RAW_LISTINGS_BATCH_SIZE=2000   # défaut
# PROCESS_RAW_LISTINGS_BATCH_SIZE=5000   # recommandé pour + throughput
# PROCESS_RAW_LISTINGS_CRON=*/5 * * * *   # toutes les 5 min (défaut)
# PROCESS_RAW_LISTINGS_CRON=*/2 * * * *   # toutes les 2 min (recommandé)

# Scrapers: parallélisme par source (défaut Leboncoin: 5 pages, 400ms délai — cible ~300k/jour)
# LEBONCOIN_CONCURRENT_PAGES=10
# LEBONCOIN_DELAY_PAGES_MS=400
# LEBONCOIN_QUEUE_DELAY_MS=200   # délai worker entre chaque URL (défaut 200)
# MOBILEDE_CONCURRENT_PAGES=8
# MOBILEDE_BATCH_DELAY_MS=1500

# Autres jobs (optionnel)
# ENABLE_IMAGE_BACKFILL=false
# ENABLE_ARBITRAGE_DETECTION=false
# ENABLE_RAW_LISTINGS_PROCESSOR=true
# LISTING_CACHE_REFRESH_CRON=*/15 * * * *   # rafraîchir "Updated Xm ago" (défaut: toutes les 15 min)

# Bytbil import depuis scraper_listings (Supabase)
# ENABLE_SUPABASE_BYTBIL_IMPORT=false  # désactiver quand focus sur 6 sources (blocket, leboncoin, etc.)

# Django import (désactivé - serveurs Oleg non utilisés, on utilise les scrapers Node)
# ENABLE_DJANGO_IMPORT=true
# ENABLE_DJANGO_LEBONCOIN_IMPORT=true
# ENABLE_DJANGO_MOBILEDE_IMPORT=true
# SUPABASE_BYTBIL_IMPORT_CRON=0 3 * * *  # défaut: 3h
# RUN_SUPABASE_BYTBIL_IMPORT_ON_STARTUP=true  # lancer au démarrage

# Django/Oleg URLs (si réactivation manuelle)
# DJANGO_MOBILEDE_BASE_URL=http://...
# DJANGO_LEBONCOIN_BASE_URL=http://...
# Django mobile.de credentials (port 8002 - Bytbil=8001)
DJANGO_MOBILEDE_USERNAME=admin
DJANGO_MOBILEDE_PASSWORD=xxx
# Filtrer status=OK uniquement (~1M listings)
DJANGO_API_CARS_QUERY=status=OK

# Scrape.do (REQUIS en prod pour LeBonCoin, Subito, coches.net, OtoMoto, 2ememain)
# Fallback anti-bot pour Blocket, Bytbil, mobile.de, Gaspedaal, etc.
# Sans token: plusieurs scrapers échoueront. https://scrape.do
SCRAPE_DO_TOKEN=

# mobile.de : accélérer le scraping (serveur dédié)
# mobile.de – réglé pour limiter 502/410 (scrape.do export 03/2026)
# MOBILEDE_MAX_PAGES=200        # pages par URL (défaut 200)
# MOBILEDE_CONCURRENT_PAGES=24  # pages en parallèle (défaut 12, 24 pour + throughput)
# MOBILEDE_BATCH_DELAY_MS=400   # délai entre lots (défaut 800ms, 400 pour + rapide)
# MOBILEDE_PARALLEL_URLS=4      # URLs scrapées en parallèle (défaut 2)
# ETA "→ 100%" : capacité cible par source (défaut: 0 = rythme réel uniquement)
# Pour forcer une capacité optimiste: MOBILEDE_ESTIMATED_SAVED_PER_DAY=86000
# MOBILEDE_ESTIMATED_SAVED_PER_DAY=86000
# MOBILEDE_USE_WATERMARK=true    # arrêter tôt quand déjà connu (économise crédits quand catalogue à jour)
# AUTOSCOUT24_ESTIMATED_SAVED_PER_DAY=50000
# LEBONCOIN_ESTIMATED_SAVED_PER_DAY=50000
# LARGUS_ESTIMATED_SAVED_PER_DAY=15000
# LACENTRALE_ESTIMATED_SAVED_PER_DAY=15000
# BLOCKET_ESTIMATED_SAVED_PER_DAY=10000
# SUBITO_ESTIMATED_SAVED_PER_DAY=12000
# FINN_ESTIMATED_SAVED_PER_DAY=12000
# OTOMOTO_ESTIMATED_SAVED_PER_DAY=15000
# MOBILEDE_QUEUE_DELAY_MS=1500  # délai worker (défaut 1500)
# MOBILEDE_QUEUE_DELAY_MS=800   # recommandé pour + throughput

# Désactiver l'enrichissement OpenAI (leboncoin, largus, etc.) pour maximiser la vitesse
# DISABLE_AI_ENRICHMENT=true

# Raw ingest: taille des lots pour saveRawListings (défaut 200)
# RAW_INGEST_BATCH_SIZE=500   # recommandé pour + throughput


# Parallélisme pour les autres sources (défaut 5)
# AUTOSCOUT24_CONCURRENT_PAGES=5
# BLOCKET_CONCURRENT_PAGES=5
# BLOCKET_CONCURRENT_DETAILS=5
# LEBONCOIN_CONCURRENT_PAGES=10
# LEBONCOIN_CONCURRENT_DETAILS=5
# LACENTRALE_CONCURRENT_PAGES=5
# LACENTRALE_CONCURRENT_DETAILS=5
# LARGUS_MAX_PAGES=50
# LARGUS_CONCURRENT_DETAILS=5

# VPS : utiliser Chromium système pour éviter "libglib-2.0.so.0" et erreurs Puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Reprise import (page où reprendre après interruption)
# DJANGO_IMPORT_START_PAGE=6157
# Si l'API Django utilise ?page= au lieu de ?offset= :
# DJANGO_IMPORT_USE_PAGE_PARAM=1
