{
  "name": "carindex",
  "version": "1.0.0",
  "description": "Carindex - Automotive Market Intelligence Platform",
  "scripts": {
    "check-vps-activity": "cd backend && node src/scripts/check-vps-activity.js",
    "postinstall": "node -e \"if (!process.env.RAILWAY_ENVIRONMENT && !process.env.CI) { require('child_process').execSync('npm install --prefix frontend', {stdio:'inherit'}) }\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:backend:api": "cd backend && npm run dev:backend:api",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:vps": "cd frontend && VITE_API_TARGET=http://91.99.61.232:3000 npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "install:all": "cd frontend && npm install && cd ../backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}









